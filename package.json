{
  "name": "sql-git",
  "version": "0.1.0",
  "description": "Distributed SQLite storage with per-peer logs, master squashing, and rebase-style conflict resolution.",
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/WjcmeAFJb/sql-git.git"
  },
  "homepage": "https://WjcmeAFJb.github.io/sql-git/",
  "keywords": [
    "sqlite",
    "distributed",
    "offline-first",
    "crdt",
    "opfs",
    "syncthing",
    "action-log",
    "rebase",
    "conflict-resolution"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./fs-node": "./src/fs-node.ts",
    "./fs-opfs": "./src/fs-opfs.ts",
    "./fs": "./src/fs.ts"
  },
  "files": [
    "src",
    "demo/actions.ts",
    "demo/app.tsx",
    "demo/tracker.tsx",
    "demo/syncer.ts",
    "LICENSE",
    "COPYING",
    "COPYING.LESSER",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chokidar": "^4.0.3",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "sqlite3-read-tracking": "file:../sql-read-tracking"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "bin": {
    "tracker": "demo/tracker.tsx",
    "syncer": "demo/syncer.ts"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
