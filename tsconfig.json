{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "lib": ["ES2023"],
    "types": ["node", "react"],
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*", "tests/**/*", "demo/**/*", "e2e/**/*"]
}
